<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- WebView JIT compilation -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory for WebView -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Disable executable page protection for WebView -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>
    <!-- Allow dyld environment variables -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Disable library validation for plugin loading -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Audio input for voice features -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Network access for API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Network server for local gateway -->
    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>
