{
  "name": "@hermes/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "DESKTOP_BACKEND_PORT=18080 DESKTOP_BACKEND_TOKEN=dev-secret uv run --directory sidecar python -m daemon",
    "build": "vite build",
    "tauri": "tauri",
    "backend:build": "bash sidecar/scripts/build_dist.sh",
    "tauri:dev": "npm run backend:build && tauri dev",
    "tauri:build": "tauri build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:css-tokens": "bash scripts/check-css-tokens.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@shikijs/engine-javascript": "^4.1.0",
    "@solidjs/router": "^0.16.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@tauri-apps/plugin-window-state": "^2",
    "dompurify": "^3.4.5",
    "lucide-solid": "^1.14.0",
    "marked": "^18.0.3",
    "shiki": "^4.1.0",
    "solid-js": "^1.9",
    "unicode-animations": "^1.0.3",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8",
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^10",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0",
    "vite": "^8",
    "vite-plugin-solid": "^2",
    "vitest": "^4"
  }
}
