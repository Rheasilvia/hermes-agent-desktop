{
  "name": "@hermes/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "DESKTOP_BACKEND_PORT=18080 DESKTOP_BACKEND_TOKEN=dev-secret uv run --directory sidecar python -m daemon",
    "build": "vite build",
    "tauri": "tauri",
    "backend:build": "bash sidecar/scripts/build_dist.sh",
    "tauri:dev": "npm run backend:build && tauri dev",
    "tauri:build": "tauri build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:css-tokens": "bash scripts/check-css-tokens.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@shikijs/engine-javascript": "^4.2.0",
    "@solidjs/router": "^0.16.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "dompurify": "^3.4.8",
    "lucide-solid": "^1.17.0",
    "marked": "^18.0.5",
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13",
    "unicode-animations": "^1.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.2",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  }
}
